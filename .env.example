# Mission Control environment template
# Copy to .env.local for Next.js runtime and .env for worker processes if needed.

# Storage backend for outbound engine: sqlite | postgres | noop
OUTBOUND_STORE=sqlite

# Optional: custom SQLite DB path (default managed by project)
OUTBOUND_SQLITE_PATH=./outbound-engine/outbound.db

# Required when OUTBOUND_STORE=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Optional: map Twilio "To" numbers to internal account IDs
# Format: +18885550111:WHOLESALE,+18885550112:AGENCY
OUTBOUND_ACCOUNT_BY_TO=

# Optional: escalation webhook for urgent inbound intents
OUTBOUND_ESCALATION_WEBHOOK_URL=

# Optional: send escalation alerts via OpenClaw messaging plugin
OUTBOUND_ESCALATION_CHANNEL=
OUTBOUND_ESCALATION_TARGET=

# Optional: worker identity for logs
OUTBOUND_WORKER_ID=

# Optional: used by npm run healthcheck (defaults to http://127.0.0.1:3000)
MISSION_CONTROL_URL=http://127.0.0.1:3000

# Outreach adapters (live mode)
# X / Twitter
X_BEARER_TOKEN=
# Lock publishing to one identity (recommended)
X_ALLOWED_USER_ID=
X_IDENTITY_STRICT=true

# Reddit (script app + refresh token)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_USER_AGENT=mission-control/1.0 by YOUR_REDDIT_USERNAME
REDDIT_DEFAULT_SUBREDDIT=test

# Outbound Twilio lane gate (default off until credentials are ready)
OUTBOUND_TWILIO_ENABLED=false
