<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.missioncontrol.outbound-worker</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd /Users/terminal/.openclaw/workspace/mission-control &amp;&amp; npm run worker:outbound</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/terminal/.openclaw/workspace/mission-control</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/Users/terminal/.npm-global/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
      <key>OPENCLAW_BIN</key>
      <string>/Users/terminal/.npm-global/bin/openclaw</string>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/terminal/.openclaw/workspace/mission-control/logs/outbound-worker.out.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/terminal/.openclaw/workspace/mission-control/logs/outbound-worker.err.log</string>
  </dict>
</plist>
